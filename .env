VITE_API_BASE_URL=http://localhost:5000
VITE_KIBANA_URL=http://localhost:5601
VITE_APP_NAME=Sentinel IoT
VITE_ENABLE_KIBANA_EMBED=true
VITE_DEFAULT_LIMIT=50
VITE_REQUEST_TIMEOUT_MS=10000
VITE_AUTH_MODE=backend

# Former production example values kept inline so the env data is still in one file.
